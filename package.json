{
  "name": "soulwinning-tracker",
  "private": true,
  "version": "1.0.0",
  "description": "Soulwinning tracker with sessions, people, tags, and stats.",
  "type": "module",
  "productName": "Soulwinning Tracker",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "build:desktop": "npm run build && electron-builder --win",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "electron-updater": "^6.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "wait-on": "^8.0.4"
  },
  "build": {
    "appId": "com.soulwinning.tracker",
    "productName": "Soulwinning Tracker",
    "artifactName": "Soulwinning-Tracker-Setup-${version}.exe",
    "publish": [
      {
        "provider": "github",
        "owner": "gurucam",
        "repo": "SoulwinningTracker"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "swt.png"
    ],
    "asarUnpack": [
      "electron/preload.cjs"
    ],
    "icon": "swt.png",
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "win": {
      "icon": "swt.png",
      "target": "nsis"
    }
  }
}
